# Copy this file to .env and fill in your values
#   cp .env.example .env

# ── Anthropic ────────────────────────────────────────────────────────────────

# Your Anthropic API key (required)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-key-here

# Claude model to use
MODEL_NAME=claude-sonnet-4-20250514

# Max tokens for LLM responses
MAX_TOKENS=1024

# ── SCB API ───────────────────────────────────────────────────────────────────

# Base URL for the SCB Statistical Database API (PxWebApi v2)
# Default is correct for most cases
SCB_API_BASE_URL=https://statistikdatabasen.scb.se/api/v2

# ── Session ───────────────────────────────────────────────────────────────────

# How long (in seconds) to keep an idle session in memory before expiring it
SESSION_TTL_SECONDS=3600
